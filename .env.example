# Google Apps Script Web App URL that receives RSVP submissions.
# Copy this file to `.env.local` (gitignored) and paste your deployment URL.
# Setup instructions: apps-script/README.md
VITE_RSVP_ENDPOINT=https://script.google.com/macros/s/REPLACE_ME/exec

# Set to "1" to preview the floating wishes overlay with sample data
# (no backend required). Useful while you're styling the overlay or before
# you've finished the Apps Script deployment. Comment out / delete to use
# the real endpoint.
# VITE_RSVP_MOCK=1
